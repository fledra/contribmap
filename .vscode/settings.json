{
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "editor.quickSuggestions": {
    "strings": "on"
  },
  "tailwindCSS.classAttributes": ["class", "ui"],
  "tailwindCSS.experimental.classRegex": [
    ["ui:\\s*{([^)]*)\\s*}", "(?:'|\"|`)([^']*)(?:'|\"|`)"]
  ],
  "json.schemas": [{
    "fileMatch": [
      ".contribmaprc",
      "contribmap.config.json"
    ],
    "url": "./public/schema.json"
  }],
  "yaml.schemas": {
    "public/schema.json": [
      "contribmap.config.yaml",
      "contribmap.config.yml"
    ]
  }
}
