{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "contribmap config schema",
  "definitions": {
    "forge": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Optional display name to differentiate instances",
          "examples": ["Personal GitHub", "Work GitLab"]
        },
        "forge": {
          "enum": ["github", "gitlab", "gitlab-self", "codeberg", "forgejo", "gitea"],
          "description": "The git service provider"
        },
        "username": {
          "type": "string",
          "description": "Your username on the platform"
        },
        "token": {
          "type": "string",
          "description": "The name of the environment variable containing your API token (e.g. GITHUB_TOKEN)",
          "examples": ["TOKEN_VARIABLE_NAME"]
        },
        "baseURL": {
          "type": "string",
          "format": "uri",
          "description": "The root URL for self-hosted instances only",
          "examples": ["https://git.yourdomain.com"]
        }
      },
      "required": ["forge", "username"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "forge": {
                "enum": ["gitlab-self", "gitea", "forgejo"]
              }
            }
          },
          "then": {
            "required": ["baseURL"]
          },
          "else": {
            "properties": {
              "baseURL": false
            }
          }
        }
      ]
    },
    "profile": {
      "type": "array",
      "items": { "$ref": "#/definitions/forge" },
      "minItems": 1,
      "additionalItems": false
    }
  },
  "type": "object",
  "properties": {
    "$schema": { "type": "string" },
    "default": { "$ref": "#/definitions/profile" }
  },
  "patternProperties": {
    "^(?!\\$schema$)[a-zA-Z0-9-_]+$": {
      "$ref": "#/definitions/profile"
    }
  },
  "minProperties": 1,
  "additionalProperties": false
}
